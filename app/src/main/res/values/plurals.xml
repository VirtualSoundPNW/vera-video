<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Counts need plurals rather than "%d videos": languages differ in how many
      plural forms they have, and English alone still needs "1 video".
    -->
    <plurals name="playlist_video_count">
        <item quantity="one">%1$d video</item>
        <item quantity="other">%1$d videos</item>
    </plurals>

    <plurals name="saved_search_count">
        <item quantity="one">%1$d match</item>
        <item quantity="other">%1$d matches</item>
    </plurals>
</resources>
