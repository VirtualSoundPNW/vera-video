<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. Playlists and saved searches are
  user-created and worth keeping; the video catalog is a cache that re-syncs
  from the backend, so there is no point shipping it to the cloud.
  (backup_rules.xml covers Android 11 and below.)
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="vera-video.db" />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="vera-video.db" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
